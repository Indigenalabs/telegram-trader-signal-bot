# Copy to .env and fill in your values

# Telegram — same bot token and chat ID as the signal bot
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=

# Binance read-only API key (used for market data only, no trading)
BINANCE_API_KEY=

# Database location
SCALPER_DB_PATH=data/scalper.db

# Signal bot data directory — scalper writes outcomes here to share learning
SIGNAL_BOT_DATA_DIR=/opt/telegram-trader-signal-bot/data

# Path to the signal bot's regime file
REGIME_FILE=/opt/telegram-trader-signal-bot/data/market_regime.json

# Tickers to watch (Binance-style or with -USD suffix)
SCALPER_TICKERS=BTC-USD,ETH-USD,SOL-USD,BNB-USD,XRP-USD

# Paper trading mode (keep true until you have 100+ trades with edge)
PAPER_TRADING=true

# Starting capital for paper P&L tracking
SCALPER_CAPITAL=5000

# Risk per trade as fraction of capital (0.01 = 1%)
SCALPER_RISK_PER_TRADE=0.01

# Exit parameters
SCALPER_TP_ATR=1.5
SCALPER_SL_ATR=1.0
SCALPER_MAX_HOLD_MINUTES=30

# Signal quality filters
SCALPER_MIN_VOL_RATIO=1.2
SCALPER_MAX_TRADES=3

# How often to scan for new signals (seconds)
SCALPER_SCAN_INTERVAL=60

# UTC hour for daily P&L report (matches signal bot default)
SCALPER_REPORT_HOUR_UTC=8

# Minimum paper trades before live-readiness alert
MIN_PAPER_TRADES_FOR_LIVE=100
